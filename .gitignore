# Terraform working directory
.terraform/

# Terraform state files
*.tfstate
*.tfstate.*

# Crash logs
crash.log
crash.*.log

# Variable files may contain secrets
*.tfvars
*.tfvars.json

# Terraform plan files
*.tfplan

# Terraform CLI configuration
.terraformrc
terraform.rc

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Sensitive environment files
.env
.env.*

# OS and editor files
.DS_Store
Thumbs.db
.vscode/
.idea/